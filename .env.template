# Database settings
POSTGRES_USER=mobilizon
POSTGRES_PASSWORD=changethis
POSTGRES_DB=mobilizon
POSTGRES_PORT=5432

# Instance configuration
MOBILIZON_INSTANCE_REGISTRATIONS_OPEN=false
MOBILIZON_INSTANCE_NAME=My Mobilizon Instance
MOBILIZON_INSTANCE_HOST=mobilizon.lan
MOBILIZON_INSTANCE_PORT=4000

MOBILIZON_INSTANCE_SECRET_KEY_BASE=changethis
MOBILIZON_INSTANCE_SECRET_KEY=changethis

MOBILIZON_INSTANCE_EMAIL=noreply@mobilizon.lan
MOBILIZON_REPLY_EMAIL=contact@mobilizon.lan

# Email settings
MOBILIZON_SMTP_SERVER=localhost
MOBILIZON_SMTP_PORT=25
MOBILIZON_SMTP_USERNAME=noreply@mobilizon.lan
MOBILIZON_SMTP_PASSWORD=password
MOBILIZON_SMTP_SSL=false

# When using docker for development, VITE_HOST must be set to 0.0.0.0
VITE_HOST=localhost

# When true, group moderators can work while the group is pending approval; group events stay non-public until the group is approved (restart required).
# Docker dev (make start) defaults this to true in docker-compose; set to false locally if you need the old behavior.
MOBILIZON_RESTRICTIONS_ALLOW_MODERATOR_ACTIVITY_FOR_PENDING_GROUPS=true

# When true, only instance administrators can create new groups (restart required).
MOBILIZON_RESTRICTIONS_ONLY_ADMIN_CAN_CREATE_GROUPS=false

# When true, only group actors can create events; individual user profiles cannot (restart required).
MOBILIZON_RESTRICTIONS_ONLY_GROUPS_CAN_CREATE_EVENTS=false

# ── Survey plugin (pragmatic-forms) ──────────────────────────────────────────

# --- Build-time: cloning the private repo ---
# GitHub Personal Access Token with `repo` (read) scope.
# Create one at: https://github.com/settings/tokens → "Classic" → check "repo"
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
# org/repo path of the pragmatic-forms repository (no https://, no .git suffix)
PRAGMATIC_FORMS_REPO=pragmaticcoders/pragmatic-forms
# Branch or tag to clone (default: main)
PRAGMATIC_FORMS_REF=main

# --- Mobilizon feature flags ---
# Set to "false" to disable the survey plugin entirely (uses NoopAdapter).
MOBILIZON_PLUGIN_SURVEYS_ENABLED=true
# URL the browser uses to download remoteEntry.js (Module Federation).
# Step 2 (Nginx): change to the public URL, e.g. https://example.com/survey-assets
MOBILIZON_PLUGIN_SURVEYS_ADAPTER_STATIC_URL=http://localhost:8081

# --- Mobilizon ↔ Adapter shared secret ---
# Both sides must use the same value. Leave empty to disable auth (dev only).
MOBILIZON_PLUGIN_SURVEYS_API_KEY=

# --- Adapter ↔ Forms Service ---
# Uncomment FORMS_SERVICE_URL to connect the adapter to the real Forms Service
# (instead of the built-in in-memory store). Requires DATABASE_URL_ADAPTER as well.
# FORMS_SERVICE_URL=http://forms-api:3000
# Shared secret between adapter and Forms Service.
FORMS_SERVICE_API_KEY=
# Admin bypass key for Forms Service (used when FORMS_SERVICE_URL is active).
FORMS_ADMIN_API_KEY=dev-admin-key
# Adapter's own Postgres DB — only needed when FORMS_SERVICE_URL is set.
# DATABASE_URL_ADAPTER=postgresql://postgres:postgres@adapter-db:5432/adapter
